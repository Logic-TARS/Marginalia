# Marginalia Configuration
# Copy this file to .env and fill in your values

# Feishu Custom Bot Webhook URL (MVP)
# Get this from: Feishu group → Settings → Bots → Add Custom Bot
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxx

# Feishu App credentials (for future Bitable integration)
# FEISHU_APP_ID=cli_xxxx
# FEISHU_APP_SECRET=xxxx
# FEISHU_BASE_TOKEN=xxxx
# FEISHU_TABLE_ID=tblxxxx

# CORS origins (comma-separated, default: *)
# CORS_ORIGINS=http://localhost:3000,http://localhost:8080
